12 16:44:56","post_content":"","post_title":"Git","post_excerpt":"Version control for tracking changes and collaboration","post_status":"publish","comment_status":"closed","ping_status":"closed","post_password":"","post_name":"git","to_ping":"","pinged":"","post_modified":"2025-09-12 16:44:56","post_modified_gmt":"2025-09-12 16:44:56","post_content_filtered":"","post_parent":0,"guid":"https:\/\/cms.edrishusein.com\/?post_type=tech&#038;p=298","menu_order":0,"post_type":"tech","post_mime_type":"","comment_count":"0","filter":"raw"},{"ID":309,"post_author":"1","post_date":"2025-09-12 16:45:43","post_date_gmt":"2025-09-12 16:45:43","post_content":"","post_title":"GitHub","post_excerpt":"Hosting and collaboration platform for Git repositories","post_status":"publish","comment_status":"closed","ping_status":"closed","post_password":"","post_name":"github","to_ping":"","pinged":"","post_modified":"2025-09-12 16:45:43","post_modified_gmt":"2025-09-12 16:45:43","post_content_filtered":"","post_parent":0,"guid":"https:\/\/cms.edrishusein.com\/?post_type=tech&#038;p=309","menu_order":0,"post_type":"tech","post_mime_type":"","comment_count":"0","filter":"raw"},{"ID":314,"post_author":"1","post_date":"2025-09-12 16:50:18","post_date_gmt":"2025-09-12 16:50:18","post_content":"","post_title":"LocalWP","post_excerpt":"Local WordPress development environment","post_status":"publish","comment_status":"closed","ping_status":"closed","post_password":"","post_name":"localwp","to_ping":"","pinged":"","post_modified":"2025-09-12 16:50:18","post_modified_gmt":"2025-09-12 16:50:18","post_content_filtered":"","post_parent":0,"guid":"https:\/\/cms.edrishusein.com\/?post_type=tech&#038;p=314","menu_order":0,"post_type":"tech","post_mime_type":"","comment_count":"0","filter":"raw"}]},"key_features":[{"title":"AI-Powered Company Research and Fit Analysis","description":"Paste a job description to trigger a Gemini search-grounded company brief, then run a Claude fit analysis that scores your profile against your CV, GitHub activity, and memory log entries."},{"title":"Proposal Drafting and Archive","description":"Log proposals with company, budget, status, and notes. Claude generates a pitch letter from the research context, stored alongside the fit analysis and expandable inline in the archive view."},{"title":"GitHub Portfolio Sync","description":"Compares public GitHub repos against portfolio project CPTs, identifies repos with substantial READMEs missing from the portfolio, and uses Claude to generate fully populated ACF draft entries flagged for review before publishing."},{"title":"Memory Log and Blog Generation","description":"Freeform memory entries about contacts, decisions, and learnings are stored and referenced by Claude during fit analysis. Blog posts can be generated from a chosen topic and optionally anchored to a memory event, then published as WordPress drafts in one click."}],"project_gallery":[{"ID":712,"id":712,"title":"Screenshot 2026-04-26 at 17.15.01","filename":"Screenshot-2026-04-26-at-17.15.01.png","filesize":38982,"url":"https:\/\/cms.edrishusein.com\/wp-content\/uploads\/2026\/04\/Screenshot-2026-04-26-at-17.15.01.png","link":"https:\/\/cms.edrishusein.com\/projects\/work-os-wordpress-plugin\/screenshot-2026-04-26-at-17-15-01\/","alt":"","author":"1","description":"","caption":"","name":"screenshot-2026-04-26-at-17-15-01","status":"inherit","uploaded_to":706,"date":"2026-04-26 15:15:15","modified":"2026-04-26 15:15:16","menu_order":0,"mime_type":"image\/png","type":"image","subtype":"png","icon":"https:\/\/cms.edrishusein.com\/wp-includes\/images\/media\/default.png","width":352,"height":660,"sizes":{"thumbnail":"https:\/\/cms.edrishusein.com\/wp-content\/uploads\/2026\/04\/Screenshot-2026-04-26-at-17.15.01-150x150.png","thumbnail-width":150,"thumbnail-height":150,"medium":"https:\/\/cms.edrishusein.com\/wp-content\/uploads\/2026\/04\/Screenshot-2026-04-26-at-17.15.01-160x300.png","medium-width":160,"medium-height":300,"medium_l